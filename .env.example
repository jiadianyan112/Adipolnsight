# ============================================================
# AdipoInsight 环境变量配置
# ============================================================
# 复制此文件为 .env 并修改配置：
#   cp .env.example .env
# ============================================================

# ===== AI 运行模式 =====
# mock      — 使用本地 Mock 数据（无需外部依赖，默认）
# script    — 调用本地 Python/R 分析脚本
# api       — 调用外部 HTTP API（LLM、OpenGWAS）
# model     — 调用本地 AI 模型推理（GPU required）
AI_MODE=mock

# 混合模式：对各能力单独指定模式
# 格式：capability=mode,capability=mode,...
# 例如：image_segmentation=model,gwas_analysis=script
# 留空则全部使用 AI_MODE
AI_MODE_PER_SKILL=

# ===== Job 存储后端 =====
# memory — 内存存储（默认，重启丢失）
# file   — 本地 JSON 文件存储
# db     — SQLite 数据库存储（生产推荐）
AI_JOB_STORAGE=memory

# file 存储路径（仅 AI_JOB_STORAGE=file 时生效）
AI_JOB_STORAGE_PATH=storage/jobs

# ===== 文件路径 =====
# 上传文件存储目录
AI_UPLOAD_DIR=storage/uploads

# 分析结果输出目录
AI_RESULT_DIR=storage/results

# 分析脚本目录
AI_SCRIPTS_DIR=analysis_scripts

# Mock 数据目录
AI_MOCK_DATA_DIR=mock_data

# ===== 上传限制 =====
# 最大上传文件大小（字节），默认 200MB
MAX_UPLOAD_SIZE=209715200

# 允许的医学影像格式（逗号分隔）
ALLOWED_IMAGE_FORMATS=.nii,.nii.gz,.dcm,.dicom,.zip,.nrrd

# 允许的数据文件格式（逗号分隔）
ALLOWED_DATA_FORMATS=.csv,.tsv,.vcf,.vcf.gz,.bed,.bim,.fam

# ===== 数据库 =====
# SQLite 路径（默认项目根目录）
DATABASE_URL=sqlite:///adipoinsight.db

# ===== LLM 配置 =====
# 默认 mock，本地开发无需 API Key
# 切换为 deepseek 时需填写 DEEPSEEK_API_KEY
LLM_PROVIDER=mock

# --- DeepSeek ---
# API Key（必填，仅后端读取，绝不暴露到前端）
DEEPSEEK_API_KEY=
# API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 默认模型（JSON 结构化输出、意图解析、对话）
DEEPSEEK_MODEL=deepseek-v4-flash
# 推理模型（复杂报告生成、深度解读）
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
# 是否启用 DeepSeek thinking 模式
DEEPSEEK_ENABLE_THINKING=false
# 推理 effort: high / medium / low
DEEPSEEK_REASONING_EFFORT=high

# --- 通用 LLM 参数 ---
# 超时时间（毫秒）
LLM_TIMEOUT_MS=60000
# 最大重试次数
LLM_MAX_RETRIES=2
# 最大输出 token 数
LLM_MAX_TOKENS=4096
# JSON 结构化输出温度（低温 = 更确定）
LLM_JSON_TEMPERATURE=0.2
# 文本生成温度（中温 = 适度随机）
LLM_TEXT_TEMPERATURE=0.4

# --- 其他 Provider（预留） ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_LOCAL_URL=http://localhost:11434

# ===== 外部数据 API（预留） =====
# IEU OpenGWAS API 地址
OPENGWAS_API_BASE=https://gwas-api.mrcieu.ac.uk

# GWAS Catalog API
GWAS_CATALOG_API_BASE=https://www.ebi.ac.uk/gwas/api

# deCODE pQTL 数据路径（本地文件或 API）
DECODE_PQTL_PATH=

# ===== Python 脚本路径（预留） =====
# 真实分析脚本的 Python 解释器路径
# PYTHON_SCRIPT_PATH=python

# R 脚本解释器路径（TwoSampleMR）
# RSCRIPT_PATH=Rscript

# ===== 服务器配置 =====
# 后端端口
API_PORT=8000

# 前端端口
FRONTEND_PORT=5173

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5173

# ===== 任务执行 =====
# 单个任务超时时间（秒），默认 300
TASK_TIMEOUT_SECONDS=300

# 后端 worker 数量（预留，当前使用 FastAPI BackgroundTasks）
# WORKER_COUNT=4

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_FILE=logs/adipoinsight.log
